# Database Configuration
# For local development (SQLite), leave as default
# For production (PostgreSQL), use: postgresql://user:password@localhost:5432/memory_research
DATABASE_URL=sqlite:///./memory_research.db

# GenAI API Configuration — https://genai.rcac.purdue.edu
# Model (optional): gpt-oss:latest and llama4:latest are typically kept hot on RCAC.
GENAI_MODEL=gpt-oss:latest

# Single key:
# GENAI_API_KEY=sk-your-api-key-here

# Or multiple keys (comma-separated) — round-robin per GenAI call to spread rate limits:
# GENAI_API_KEYS=sk-key-one,sk-key-two

# Optional: Legacy OpenAI API key (for compatibility)
# OPENAI_API_KEY=sk-your-openai-key-here

# Secret Key (for session management)
# Generate a random string for production
SECRET_KEY=your-secret-key-here-change-in-production

# Environment
# Options: development, production
ENVIRONMENT=development
